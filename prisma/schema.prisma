generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js Required Models ────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  INVENTORY_MANAGER
  CUSTOMER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKING
  PACKED
  READY_TO_SHIP
  SHIPPED
  OUT_FOR_DELIVERY
  DISPATCHED
  DELIVERED
  DELIVERY_FAILED
  CANCELLED
  REFUNDED
  RETURN_REQUESTED
  RETURN_APPROVED
  RETURN_PICKED
  RETURN_RECEIVED
  REFUND_COMPLETED
}

enum ShipmentStatus {
  CREATED
  PACKING
  READY_TO_SHIP
  SHIPPED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  DELIVERY_FAILED
  RETURN_INITIATED
  RETURN_PICKED
  RETURNED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum StockUpdateType {
  ADD
  REMOVE
  SET
  DAMAGED
  EXPIRED
}

enum InventoryReason {
  STOCK_RECEIVED
  MANUAL_ADJUSTMENT
  DAMAGED
  RETURNED
  ORDER_CANCELLED
  INITIAL_STOCK
  ORDER_PLACED
}

enum CouponType {
  FLAT
  PERCENTAGE
  FREE_SHIPPING
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum NotificationType {
  ORDER_PLACED
  ORDER_STATUS_UPDATE
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  LOW_STOCK
  BACK_IN_STOCK
  COUPON_AVAILABLE
  LOYALTY_POINTS
  GENERAL
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  PICKED
  RECEIVED
  COMPLETED
  REFUNDED
}

// ─── Core Business Models ────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  phone         String?   @unique
  passwordHash  String?
  role          UserRole  @default(CUSTOMER)
  emailVerified DateTime?
  image         String?
  isActive      Boolean   @default(true)
  tokenVersion  Int       @default(0)
  loyaltyPoints Int       @default(0)
  loyaltyTier   String    @default("BRONZE")
  referralCode  String    @unique @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  addresses           Address[]
  orders              Order[]
  cart                Cart?
  wishlists           Wishlist[]
  reviews             Review[]
  notifications       Notification[]
  loyaltyTransactions LoyaltyTransaction[]
  referralsGiven      Referral[]           @relation("ReferrerUser")
  referralsReceived   Referral[]           @relation("RefereeUser")
  couponUsages        CouponUsage[]
  subscriptions       Subscription[]
  inventoryLogs       InventoryLog[]
  returnRequests      ReturnRequest[]
  wallet              Wallet?
  wishlistCollections WishlistCollection[]
  reviewHelpfuls      ReviewHelpful[]
  shipmentsCreated    Shipment[]           @relation("ShipmentCreatedBy")
  exchangeRequests    ExchangeRequest[]
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  name      String
  phone     String
  line1     String
  line2     String?
  city      String
  state     String
  pincode   String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders        Order[]
  subscriptions Subscription[]
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  seoTitle    String?
  seoDesc     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]
  promotions  PromotionCategory[]
}

model Product {
  id                     String        @id @default(cuid())
  name                   String
  slug                   String        @unique
  description            String?       @db.Text
  shortDescription       String?
  categoryId             String
  images                 String[]      @default([])
  tags                   String[]      @default([])
  dietaryTags            String[]      @default([])
  nutritionalInfo        Json?
  allergenInfo           String?
  returnWindowDays       Int           @default(0)
  isFeatured             Boolean       @default(false)
  isSubscriptionEligible Boolean       @default(true)
  status                 ProductStatus @default(ACTIVE)
  seoTitle               String?
  seoDesc                String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  category      Category         @relation(fields: [categoryId], references: [id])
  variants      ProductVariant[]
  wishlists     Wishlist[]
  reviews       Review[]
  orderItems    OrderItem[]
  cartItems     CartItem[]
  subscriptions Subscription[]
  productMedia  ProductMedia[]
  promotions    PromotionProduct[]
}

model ProductVariant {
  id                String   @id @default(cuid())
  productId         String
  weight            String
  price             Float
  mrp               Float
  sku               String   @unique
  stock             Int      @default(0)
  lowStockThreshold Int      @default(10)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems     CartItem[]
  orderItems    OrderItem[]
  inventoryLogs InventoryLog[]
  subscriptions Subscription[]
}

model Cart {
  id        String     @id @default(cuid())
  userId    String?    @unique
  sessionId String?    @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user  User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  variantId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([cartId, variantId])
}

model Order {
  id             String        @id @default(cuid())
  orderNumber    String        @unique
  userId         String
  addressId      String?
  status         OrderStatus   @default(PENDING)
  subtotal       Float
  discountAmount Float         @default(0)
  deliveryCharge Float         @default(0)
  total          Float
  paymentMethod    String?
  paymentStatus    PaymentStatus @default(PENDING)
  transactionId    String?
  razorpayOrderId  String?       @unique
  couponId       String?
  pointsUsed       Int           @default(0)
  walletAmountUsed Float         @default(0)
  gstRequired      Boolean       @default(false)
  giftMessage    String?
  notes          String?
  trackingNumber String?
  deliveredAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user              User              @relation(fields: [userId], references: [id])
  address           Address?          @relation(fields: [addressId], references: [id])
  coupon            Coupon?           @relation(fields: [couponId], references: [id])
  items             OrderItem[]
  returnRequest     ReturnRequest?
  shipment          Shipment?
  exchangeRequests  ExchangeRequest[]
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  productId       String
  variantId       String
  quantity        Int
  unitPrice       Float
  totalPrice      Float
  reviewSubmitted Boolean  @default(false)

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])
}

model Coupon {
  id              String     @id @default(cuid())
  code            String     @unique
  type            CouponType
  value           Float
  minOrderValue   Float      @default(0)
  maxDiscount     Float?
  totalUsageLimit Int?
  perUserLimit    Int        @default(1)
  usageCount      Int        @default(0)
  validFrom       DateTime
  validUntil      DateTime
  isActive        Boolean    @default(true)
  description     String?
  createdAt       DateTime   @default(now())

  usages CouponUsage[]
  orders Order[]
}

model CouponUsage {
  id             String   @id @default(cuid())
  couponId       String
  userId         String
  orderId        String
  discountAmount Float
  usedAt         DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([couponId, userId])
}

model Review {
  id            String   @id @default(cuid())
  userId        String
  productId     String
  orderId       String?
  rating        Int
  title         String?
  body          String?  @db.Text
  images        String[] @default([])
  videos        String[] @default([])
  isAnonymous   Boolean  @default(false)
  isFeatured    Boolean  @default(false)
  helpfulCount  Int      @default(0)
  status        String   @default("PENDING")
  adminResponse String?  @db.Text
  createdAt     DateTime @default(now())

  user         User            @relation(fields: [userId], references: [id])
  product      Product         @relation(fields: [productId], references: [id])
  helpfulVotes ReviewHelpful[]
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  variantId    String?
  collectionId String?
  collection   WishlistCollection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  createdAt    DateTime            @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
}

model Subscription {
  id               String             @id @default(cuid())
  userId           String
  productId        String
  variantId        String
  addressId        String?
  frequencyDays    Int                @default(30)
  status           SubscriptionStatus @default(ACTIVE)
  nextDeliveryDate DateTime
  price            Float
  cancelReason     String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user    User           @relation(fields: [userId], references: [id])
  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])
  address Address?       @relation(fields: [addressId], references: [id])
}

model Notification {
  id            String           @id @default(cuid())
  userId        String
  type          NotificationType
  title         String
  body          String
  referenceType String?
  referenceId   String?
  isRead        Boolean          @default(false)
  createdAt     DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LoyaltyTransaction {
  id          String   @id @default(cuid())
  userId      String
  type        String
  points      Int
  refType     String?
  refId       String?
  description String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Referral {
  id             String   @id @default(cuid())
  referrerId     String
  refereeId      String
  refereeOrderId String?
  rewardPoints   Int      @default(0)
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())

  referrer User @relation("ReferrerUser", fields: [referrerId], references: [id])
  referee  User @relation("RefereeUser", fields: [refereeId], references: [id])
}

model InventoryLog {
  id               String           @id @default(cuid())
  productId        String
  variantId        String
  updatedBy        String
  updateType       StockUpdateType
  reason           InventoryReason?
  quantityChange   Int
  previousQuantity Int
  newQuantity      Int
  notes            String?
  createdAt        DateTime         @default(now())

  variant       ProductVariant @relation(fields: [variantId], references: [id])
  updatedByUser User           @relation(fields: [updatedBy], references: [id])
}

model Banner {
  id          String    @id @default(cuid())
  title       String
  image       String
  ctaText     String?
  ctaLink     String?
  slot        String    @default("HERO")
  sortOrder   Int       @default(0)
  activeFrom  DateTime?
  activeUntil DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
}

model DeliveryZone {
  id                    String   @id @default(cuid())
  name                  String
  states                String[] @default([])
  cities                String[] @default([])
  pincodes              String[]
  deliveryCharge        Float    @default(0)
  freeDeliveryThreshold Float    @default(499)
  estimatedDaysMin      Int      @default(3)
  estimatedDaysMax      Int      @default(5)
  expressEnabled        Boolean  @default(false)
  expressCharge         Float    @default(0)
  expressDaysMin        Int      @default(1)
  expressDaysMax        Int      @default(2)
  codEnabled            Boolean  @default(true)
  codMinOrderValue      Float    @default(0)
  isActive              Boolean  @default(true)
  sortOrder             Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @default(now()) @updatedAt
}

// Stores context for in-flight Razorpay payments between create-order and verify.
// Enables amount cross-check and webhook-based order recovery if the browser closes mid-flow.
model PendingPayment {
  id                  String   @id @default(cuid())
  razorpayOrderId     String   @unique
  userId              String
  addressId           String
  couponCode          String?
  expectedAmountPaise Int
  createdAt           DateTime @default(now())
  expiresAt           DateTime
}

model ReturnRequest {
  id                  String       @id @default(cuid())
  orderId             String       @unique
  userId              String
  reason              String
  reasonDetail        String?      @db.Text
  status              ReturnStatus @default(PENDING)
  adminNotes          String?      @db.Text
  images              String[]     @default([])
  preferredPickupDate DateTime?
  pickupAddress       String?
  refundAmount        Float?
  refundMethod        String?
  trackingNumber      String?
  courierName         String?
  requestedAt         DateTime     @default(now())
  resolvedAt          DateTime?

  order Order @relation(fields: [orderId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
}

// ─── Shipping & Fulfillment ──────────────────────────────────────────────────

model Courier {
  id              String   @id @default(cuid())
  name            String
  website         String?
  trackingUrlPattern String? // e.g. "https://www.bluedart.com/track?id={tracking}"
  supportPhone    String?
  supportEmail    String?
  logo            String?
  isActive        Boolean  @default(true)
  priority        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  shipments       Shipment[]
  shippingRates   ShippingRate[]
}

model Shipment {
  id                   String         @id @default(cuid())
  shipmentNumber       String         @unique
  orderId              String         @unique
  courierId            String?
  trackingNumber       String?
  trackingUrl          String?
  status               ShipmentStatus @default(CREATED)
  weightGrams          Int?
  lengthCm             Float?
  widthCm              Float?
  heightCm             Float?
  packageType          String         @default("STANDARD")
  dispatchedAt         DateTime?
  estimatedDelivery    DateTime?
  deliveredAt          DateTime?
  shippingCost         Float          @default(0)
  codCharges           Float          @default(0)
  insurance            Float          @default(0)
  notes                String?        @db.Text
  labelUrl             String?
  createdBy            String
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  order     Order           @relation(fields: [orderId], references: [id])
  courier   Courier?        @relation(fields: [courierId], references: [id], onDelete: SetNull)
  createdByUser User        @relation("ShipmentCreatedBy", fields: [createdBy], references: [id])
  events    ShipmentEvent[]
}

model ShipmentEvent {
  id          String   @id @default(cuid())
  shipmentId  String
  status      String
  title       String
  description String?
  location    String?
  isManual    Boolean  @default(true)
  createdBy   String?
  createdAt   DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
}

model ShippingRate {
  id              String   @id @default(cuid())
  name            String
  type            String   @default("FLAT") // FLAT, WEIGHT_BASED, ORDER_VALUE_BASED
  courierId       String?
  minWeightGrams  Int?
  maxWeightGrams  Int?
  minOrderValue   Float?
  maxOrderValue   Float?
  price           Float    @default(0)
  isCOD           Boolean  @default(false)
  isExpress       Boolean  @default(false)
  isActive        Boolean  @default(true)
  priority        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  courier Courier? @relation(fields: [courierId], references: [id], onDelete: SetNull)
}

model ExchangeRequest {
  id                String   @id @default(cuid())
  orderId           String
  userId            String
  originalVariantId String
  requestedVariantId String
  reason            String
  status            String   @default("PENDING") // PENDING, APPROVED, REJECTED, SHIPPED, DELIVERED
  adminNotes        String?  @db.Text
  replacementShipmentId String?
  requestedAt       DateTime @default(now())
  resolvedAt        DateTime?

  order   Order @relation(fields: [orderId], references: [id])
  user    User  @relation(fields: [userId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  role       String
  action     String
  module     String
  entityType String?
  entityId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
}

model MediaAsset {
  id           String   @id @default(cuid())
  publicId     String   @unique
  secureUrl    String
  thumbnailUrl String?
  resourceType String   @default("image")
  format       String
  bytes        Int
  width        Int?
  height       Int?
  folder       String   @default("binge-bite")
  altText      String?
  tags         String[] @default([])
  createdBy    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  heroSlides   HeroSlide[]
  productMedia ProductMedia[]
}

model HeroSlide {
  id          String      @id @default(cuid())
  heading     String      @default("")
  subheading  String      @default("")
  description String      @default("") @db.Text
  ctaText     String      @default("")
  ctaLink     String      @default("")
  mediaId     String?
  media       MediaAsset? @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  sortOrder   Int         @default(0)
  isActive    Boolean     @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model ProductMedia {
  id           String     @id @default(cuid())
  productId    String
  mediaAssetId String
  sortOrder    Int        @default(0)
  isThumbnail  Boolean    @default(false)
  createdAt    DateTime   @default(now())

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  mediaAsset MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@unique([productId, mediaAssetId])
}

model HomepageCMS {
  id String @id @default("singleton")

  // Hero
  heroBadge           String  @default("🌾 Premium Makhana — Roasted Fresh")
  heroHeading         String  @default("Snack Bold.")
  heroSubheading      String  @default("Stay Fit.")
  heroDescription     String  @default("Premium flavored makhana for the modern snacker. Zero guilt, maximum crunch, delivered to your door across India.")
  ctaText             String  @default("Shop Now")
  ctaLink             String  @default("/products")

  // Section Titles
  featuredTitle       String  @default("Customer Favorites")
  featuredBadge       String  @default("Bestsellers")
  trendingTitle       String  @default("New Arrivals")
  trendingBadge       String  @default("Just In")
  reviewsTitle        String  @default("What Customers Say")
  reviewsBadge        String  @default("Reviews")
  whyChooseTitle      String  @default("Why Choose Us")

  // Subscription Banner
  subscriptionTitle   String  @default("Never Run Out Again")
  subscriptionSubtext String  @default("Subscribe & save up to 15%. Pause, skip, or cancel anytime. No strings attached.")
  subscriptionCtaText String  @default("Start Your Subscription")
  subscriptionCtaLink String  @default("/products")

  // Visibility
  showHero            Boolean @default(true)
  showWhyChooseUs     Boolean @default(true)
  showFeatured        Boolean @default(true)
  showSubscription    Boolean @default(true)
  showTrending        Boolean @default(true)
  showReviews         Boolean @default(true)

  updatedAt DateTime @updatedAt
}

model HomepageQuote {
  id        String   @id @default(cuid())
  text      String   @db.Text
  name      String
  city      String
  rating    Int      @default(5)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Promotions & Campaign Engine ────────────────────────────────────────────

enum PromotionType {
  ANNOUNCEMENT_BAR
  HOMEPAGE_BANNER
  CATEGORY_BANNER
  PRODUCT_BANNER
  POPUP
  FLOATING_BUTTON
  COUNTDOWN_CAMPAIGN
}

model Promotion {
  id   String        @id @default(cuid())
  name String
  type PromotionType

  // Scheduling & Status
  isActive Boolean   @default(false)
  priority Int       @default(0)
  startsAt DateTime?
  endsAt   DateTime?

  // Audience & display locations
  audienceTarget String   @default("ALL_VISITORS")
  displayPages   String[] @default([])

  // All type-specific config stored as flexible JSON
  config Json @default("{}")

  // Analytics counters (denormalized for fast reads)
  impressions Int @default(0)
  clicks      Int @default(0)

  // Relations
  categories PromotionCategory[]
  products   PromotionProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PromotionCategory {
  promotionId String
  categoryId  String

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([promotionId, categoryId])
}

model PromotionProduct {
  promotionId String
  productId   String

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([promotionId, productId])
}

model WishlistCollection {
  id         String   @id @default(cuid())
  userId     String
  name       String
  slug       String
  isPublic   Boolean  @default(false)
  shareToken String   @unique @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items Wishlist[]

  @@unique([userId, slug])
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
}

model WalletTransaction {
  id          String   @id @default(cuid())
  walletId    String
  type        String
  amount      Float
  description String
  refType     String?
  refId       String?
  createdAt   DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model ReviewHelpful {
  id       String  @id @default(cuid())
  reviewId String
  userId   String
  helpful  Boolean

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
}

model LoyaltySettings {
  id                     String   @id @default("singleton")
  pointsPerRupee         Float    @default(1)
  redemptionRate         Float    @default(0.5)
  maxRedemptionPercent   Float    @default(20)
  reviewPoints           Int      @default(50)
  referralReferrerPoints Int      @default(100)
  referralRefereePoints  Int      @default(50)
  birthdayPoints         Int      @default(200)
  updatedAt              DateTime @updatedAt
}

model SiteSettings {
  id              String   @id @default("singleton")
  // Company
  companyName     String   @default("Binge Bite")
  tagline         String   @default("Premium flavored makhana, roasted to perfection.")
  aboutText       String   @default("") @db.Text
  supportEmail    String   @default("")
  supportPhone    String   @default("")
  whatsappNumber  String   @default("")
  // Social
  facebook        String   @default("")
  instagram       String   @default("")
  linkedin        String   @default("")
  twitter         String   @default("")
  youtube         String   @default("")
  // Footer
  footerText      String   @default("Premium flavored makhana. Roasted to perfection, seasoned with love. Guilt-free snacking for modern India.")
  copyrightText   String   @default("")
  // Business
  gstNumber       String   @default("")
  businessAddress String   @default("") @db.Text
  googleMapsLink  String   @default("")
  // Delivery Celebration Page
  deliveryHeadline    String  @default("Your order has been delivered! 🎉")
  deliveryMessage     String  @default("We hope you love your Binge Bite snacks. Come back for more goodness!") @db.Text
  deliveryAnimation   String  @default("CONFETTI")
  deliveryShowRating  Boolean @default(true)
  deliveryShowReorder Boolean @default(true)

  updatedAt DateTime @updatedAt
}
