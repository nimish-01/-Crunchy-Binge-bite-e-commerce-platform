# Database — PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/binge_bite?schema=public"

# NextAuth / Auth.js
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# File uploads (local path relative to project root)
UPLOAD_DIR="public/uploads"
UPLOAD_BASE_URL="/uploads"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Binge Bite"

# ─── Future integrations (leave blank until enabled) ──────────────────────────
# Razorpay (required — app refuses to start without these)
RAZORPAY_KEY_ID="rzp_live_..."
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
RAZORPAY_WEBHOOK_SECRET="your-razorpay-webhook-secret"

# Cloudinary
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Algolia
# NEXT_PUBLIC_ALGOLIA_APP_ID=
# NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=
# ALGOLIA_ADMIN_KEY=

# Twilio / MSG91
# SMS_PROVIDER=
# SMS_API_KEY=

# WhatsApp / Interakt
# WHATSAPP_API_KEY=

# SendGrid
# SENDGRID_API_KEY=

# Shiprocket
# SHIPROCKET_EMAIL=
# SHIPROCKET_PASSWORD=
